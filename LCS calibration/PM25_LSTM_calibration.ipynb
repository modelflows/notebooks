   ],
   "source": [
    "def scatter_plot(y_true, y_pred, name):\n",
    "    m = compute_metrics(y_true, y_pred)\n",
    "    fig, ax = plt.subplots(figsize=(5, 5))\n",
    "    ax.scatter(y_true, y_pred, alpha=0.4, s=15, color=\"steelblue\")\n",
    "    lims = [min(y_true.min(), y_pred.min()), max(y_true.max(), y_pred.max())]\n",
    "    ax.plot(lims, lims, \"r--\", linewidth=1, label=\"1:1 line\")\n",
    "    ax.text(0.05, 0.95,\n",
    "            f\"$R^2$ = {m['R2']:.3f}\\nMAE = {m['MAE']:.2f}\\nRMSE = {m['RMSE']:.2f}\",\n",
    "            transform=ax.transAxes, va=\"top\", fontsize=9,\n",
    "            bbox=dict(boxstyle=\"round\", facecolor=\"white\", alpha=0.7))\n",
    "    ax.set_xlabel(\"Reference PM$_{2.5}$ (µg/m³)\")\n",
    "    ax.set_ylabel(\"Calibrated PM$_{2.5}$ (µg/m³)\")\n",
    "    ax.set_title(f\"PM$_{{2.5}}$ calibration — {name}\")\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(True, linestyle=\"--\", alpha=0.4)\n",
