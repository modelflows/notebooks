   "source": [
    "## 11. Calibration results on validation and test\n",
    "\n",
    "`predict_unscaled(...)` runs the model and converts predictions back to physical units (µg/m³) with `y_scaler`. `compute_metrics(...)` returns **R², MAE and RMSE**. The table below reports both the validation and test sets.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "3140322a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "               R2    MAE   RMSE\n",
      "Validation  0.978  0.848  1.336\n",
      "Test        0.976  0.825  1.367\n"
     ]
    }
   ],
   "source": [
    "def compute_metrics(y_true, y_pred):\n",
    "    return {\n",
    "        \"R2\":   r2_score(y_true, y_pred),\n",
    "        \"MAE\":  mean_absolute_error(y_true, y_pred),\n",
    "        \"RMSE\": np.sqrt(mean_squared_error(y_true, y_pred)),\n",
    "    }\n",
    "\n",
    "def predict_unscaled(X_seq):\n",
    "    \"\"\"Predict and convert back to physical units (ug/m3).\"\"\"\n",
    "    p = model.predict(X_seq, verbose=0).ravel()\n",
    "    return y_scaler.inverse_transform(p.reshape(-1, 1)).ravel()\n",
    "\n",
    "# Validation\n",
    "y_val_true = y_scaler.inverse_transform(y_val_seq.reshape(-1, 1)).ravel()\n",
    "y_val_pred = predict_unscaled(X_val_seq)\n",
    "\n",
    "# Test\n",
    "y_test_true = y_scaler.inverse_transform(y_test_seq.reshape(-1, 1)).ravel()\n",
    "y_test_pred = predict_unscaled(X_test_seq)\n",
    "\n",
    "results = pd.DataFrame(\n",
    "    [compute_metrics(y_val_true,  y_val_pred),\n",
    "     compute_metrics(y_test_true, y_test_pred)],\n",
    "    index=[\"Validation\", \"Test\"],\n",
    ")\n",
    "print(results.round(3))"
   ]
  },
